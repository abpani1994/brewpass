# Copy to .env and fill in. docker-compose reads these via env_file.

# Postgres
POSTGRES_USER=brewpass
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=brewpass

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=

# Public base url used to build SMS invite links (use your deployed domain)
PUBLIC_BASE_URL=http://localhost:4000

# Stripe (pay-now). When unset, pay-now returns 503; pay-at-store still works.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (SMS invite links). When unset, invites stay queued in the outbox.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
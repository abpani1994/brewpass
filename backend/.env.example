# Database
DATABASE_URL=postgresql://brewpass:brewpass@db:5432/brewpass?schema=public

# Server
PORT=4000
NODE_ENV=development

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=

# Public base url used to build SMS invite links
PUBLIC_BASE_URL=http://localhost:4000

# Stripe (pay-now). When unset, pay-now returns 503; pay-at-store still works.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (SMS invite links). When unset, invites stay queued in the outbox.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  cafeName     String
  createdAt    DateTime   @default(now())

  menuItems    MenuItem[]
  customers    Customer[]
  orders       Order[]
  smsOutbox    SmsOutbox[]
}

model MenuItem {
  id         String   @id @default(uuid())
  ownerId    String
  name       String
  category   String   @default("Coffee")
  priceCents Int      @default(0)
  available  Boolean  @default(true)
  modifiers  Json     @default("[]")
  createdAt  DateTime @default(now())

  owner      Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model Customer {
  id          String    @id @default(uuid())
  ownerId     String
  name        String
  phone       String
  usualOrder  String    @default("")
  usualItemId String?
  streak      Int       @default(0)
  lastVisit   DateTime?
  orderCount  Int       @default(0)
  inviteToken String    @unique
  createdAt   DateTime  @default(now())

  owner       Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  visits      Visit[]
  orders      Order[]
  rewards     Reward[]

  @@index([ownerId])
}

model Visit {
  id         String   @id @default(uuid())
  customerId String
  visitedAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Order {
  id              String   @id @default(uuid())
  ownerId         String
  customerId      String
  itemSummary     String
  totalCents      Int      @default(0)
  status          String   @default("preparing")
  payStatus       String   @default("pay_at_store")
  pickupAt        DateTime
  stripeSessionId String?
  createdAt       DateTime @default(now())

  owner           Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([customerId])
}

model Reward {
  id         String   @id @default(uuid())
  customerId String
  redeemed   Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model SmsOutbox {
  id        String   @id @default(uuid())
  ownerId   String
  phone     String
  body      String
  status    String   @default("queued")
  createdAt DateTime @default(now())

  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}